%% Norn — sidecar architecture for Lightdash
flowchart TB

    analyst([Analyst])
    cli["CLI / orchestrator<br/>norn up — one command"]

    subgraph monorepo["Monorepo: tysee/norn"]
        direction TB
        agent["packages/agent<br/>Dependency-analysis agent<br/>(pi.dev)"]
        forecast["packages/forecast<br/>Forecast service<br/>(TimesFM 2.5 worker)"]
        mcp["MCP server<br/>(FastMCP, agent interface)"]
        tfmworker["TimesFM worker<br/>(FastAPI, torch container)"]
        integ["packages/integration<br/>Glue: dbt + Lightdash + ClickHouse"]
        meta[("addon Postgres<br/>metadata: jobs, runs,<br/>deps, metric_def")]
    end

    subgraph existing["Existing stack (not forked)"]
        direction TB
        lightdash["Lightdash<br/>BI / dashboards / semantic"]
        ldpg[("Lightdash Postgres<br/>projects, dbt metrics")]
        ch[("ClickHouse<br/>marts, forecast tables,<br/>actual_vs_forecast")]
        dbt["dbt project<br/>metrics and grain"]
    end

    llm["LLM provider<br/>dependency explanation"]

    analyst --> cli
    cli --> integ
    cli --> forecast
    cli --> agent

    integ -->|reads metric definitions| ldpg
    integ -->|builds/reads marts| ch
    integ -->|registers forecast models| dbt
    dbt --> ch

    forecast -->|extract series| ch
    forecast -->|write-back forecast_point| ch
    forecast -->|HTTP /forecast| tfmworker
    lightdash -->|reads dbt actual_vs_forecast| ch
    mcp -->|reads forecast_point / forecast_segment| ch
    agent -->|MCP tools| mcp
    forecast --> meta

    agent -->|reads series| ch
    agent -->|correlations + lags| meta
    agent -->|explanation| llm

    lightdash -->|actual vs forecast| ch
    lightdash --> ldpg
    analyst -->|views dashboard| lightdash

    classDef ours fill:#E8C8BA,stroke:#B8553E,color:#1C1814;
    classDef ext fill:#EFE6CF,stroke:#8C8275,color:#1C1814;
    class agent,forecast,mcp,integ,meta,cli ours;
    class lightdash,ldpg,ch,dbt ext;
