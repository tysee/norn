# ---------------------------------------------------------------------------
# Local Lightdash stack — copy to `.env` and adjust. `.env` is gitignored.
#   cd deploy && cp .env.example .env
# ---------------------------------------------------------------------------

# --- ClickHouse (warehouse) -------------------------------------------------
# These feed the clickhouse service AND the dbt profile (profiles.yml reads
# CH_HOST). Inside the compose network the host is the service name `clickhouse`.
CH_HOST=clickhouse
CLICKHOUSE_DB=norn
CLICKHOUSE_USER=norn
CLICKHOUSE_PASSWORD=norn

# --- Lightdash server -------------------------------------------------------
# Must stay constant across restarts or you lose access to existing data.
LIGHTDASH_SECRET=local-dev-secret
SITE_URL=http://localhost:8080

# --- Headless bootstrap (creates the first admin + project automatically) ---
# The first user registered on a fresh instance becomes the org admin.
LD_ADMIN_EMAIL=admin@norn.local
LD_ADMIN_PASSWORD=norn-admin-pw1
LD_ADMIN_FIRST_NAME=Norn
LD_ADMIN_LAST_NAME=Admin
LD_ORG_NAME=Norn

# Defaults publish the bundled GENERIC demo project. To ship a DOMAIN instance
# (e.g. crypto), do NOT edit these — use that instance's env-file instead:
#   docker compose -f deploy/docker-compose.yml \
#     --env-file instances/<domain>/deploy/.env --profile setup run --rm lightdash-init
LD_PROJECT_NAME=norn-demo

# Which dbt project to publish to Lightdash. Path is relative to deploy/.
DBT_PROJECT_HOST_DIR=./dbt

# Both compose files share one project; each sees the other's containers as
# "orphans" — this silences the cosmetic warning. NEVER pass --remove-orphans.
COMPOSE_IGNORE_ORPHANS=true
